MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"

# JWT Secret Key (change in production)
JWT_SECRET_KEY="clubvel-secret-key-change-in-production"

# Twilio Configuration for WhatsApp OTP and SMS
# Get these from https://console.twilio.com/
# Leave empty or set ENABLE_REAL_NOTIFICATIONS=false for mock mode
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""  # Your Twilio phone number for SMS (e.g., +15551234567)
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"  # Default Twilio sandbox number

# Set to 'true' to enable real WhatsApp/SMS notifications
# When 'false', OTP is always 1234 and messages are logged but not sent
ENABLE_REAL_NOTIFICATIONS=false

# Stitch Money API Configuration for Bank Feed Integration
# Get these from https://stitch.money/developers
# Leave empty or set ENABLE_BANK_FEED=false for mock mode
STITCH_API_KEY=""
STITCH_API_SECRET=""
STITCH_ENVIRONMENT="sandbox"  # sandbox or production

# Set to 'true' to enable real bank feed integration
# When 'false', uses mock bank accounts and transactions
ENABLE_BANK_FEED=false